---
import Layout from '../layouts/Layout.astro';

const articles = [
  {
    slug: "elevenlabs",
    title: "ElevenLabs Review 2026: Best AI Voice Generator?",
    description: "We tested ElevenLabs for 2 weeks — voice cloning, text-to-speech, multilingual support. Here's our honest verdict.",
    tag: "Voice & TTS",
    score: "9.1/10",
    date: "Apr 2, 2026"
  },
  {
    slug: "writesonic",
    title: "Writesonic Review 2026: AI Content Writer Worth It?",
    description: "Honest Writesonic review — features, pricing, GPT-4 quality, and whether it beats Jasper and Copy.ai.",
    tag: "AI Writing",
    score: "8.0/10",
    date: "Apr 2, 2026"
  },
  {
    slug: "copy-ai",
    title: "Copy.ai Review 2026: Is It the Best AI Writing Tool?",
    description: "In-depth Copy.ai review after 2 weeks of testing. Features, pricing, pros & cons, and whether it's worth it.",
    tag: "AI Writing",
    score: "8.2/10",
    date: "Apr 2, 2026"
  }
];
---

<Layout
  title="AI Compare Hub — Best AI Tools Reviewed"
  description="Honest reviews and comparisons of the best AI tools. Find the perfect AI tool for your workflow."
>
  <section class="hero">
    <div class="container">
      <h1>Find the Best AI Tools,<br><span class="accent">Without the Hype.</span></h1>
      <p>Real reviews. Side-by-side <a href="/comparisons">comparisons</a>. No fluff.</p>
      <a href="/tools" class="btn">Browse Tools →</a>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Latest Reviews</h2>
      <div class="grid">
        {articles.map(article => (
          <a href={`/reviews/${article.slug}`} class="card">
            <span class="tag">{article.tag}</span>
            <h3>{article.title}</h3>
            <p>{article.description}</p>
            <div class="card-meta">
              <span>{article.date}</span>
              <span class="score">{article.score}</span>
            </div>
          </a>
        ))}
      </div>
      <div class="section-cta">
        <a href="/tools" class="btn btn-outline">View All Reviews →</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container center">
      <div class="newsletter">
        <h2>Get notified when we publish</h2>
        <p>No spam. Just honest AI tool reviews.</p>
        <form class="newsletter-form">
          <input type="email" name="email" placeholder="your@email.com" required aria-label="Email address">
          <button type="submit" class="btn">Subscribe</button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.querySelector('.newsletter-form')?.addEventListener('submit', e => {
    e.preventDefault();
    alert('Subscribed! 🎉');
    (e.target as HTMLFormElement).reset();
  });
</script>

<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "AI Compare Hub",
  "url": "https://aicomparehub.blog/",
  "description": "Honest reviews and comparisons of the best AI tools.",
  "publisher": {
    "@type": "Organization",
    "name": "AI Compare Hub",
    "url": "https://aicomparehub.blog/",
    "logo": {
      "@type": "ImageObject",
      "url": "https://aicomparehub.blog/favicon.svg"
    }
  }
}
</script>
