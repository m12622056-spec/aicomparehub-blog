---
import Layout from '../layouts/Layout.astro';
import { articles } from '../data/articles';
---

<Layout
  title="Best AI Tools 2026 — AI Compare Hub"
  description="Browse our tested and reviewed AI tools. Honest ratings, no bias. Find the best AI tools for writing, design, coding, and more."
>
  <section class="article">
    <h1>AI Tools</h1>
    <p class="excerpt">Every tool we've tested and reviewed. Honest ratings, no bias.</p>
    
    <div class="grid" style="margin-top: 2rem;">
      {articles.map(article => (
        <a href={`/reviews/${article.slug}`} class="card">
          <span class="tag">{article.category}</span>
          <h3>{article.title.split(' Review')[0]}</h3>
          <p>{article.description.split('.').slice(0, 2).join('.')}.</p>
          <div class="card-meta">
            <span style="color: var(--green); font-weight: 600;">{article.price}</span>
            <span class="score">{article.score}</span>
          </div>
        </a>
      ))}
    </div>
    
    <p style="margin-top: 2rem;">Looking for head-to-head matchups? Check out our <a href="/comparisons">comparisons</a> or browse <a href="/deals">exclusive deals</a>.</p>
  </section>
</Layout>

<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Best AI Tools 2026",
  "url": "https://aicomparehub.blog/tools",
  "description": "Browse our tested and reviewed AI tools. Honest ratings, no bias.",
  "isPartOf": {
    "@type": "WebSite",
    "name": "AI Compare Hub",
    "url": "https://aicomparehub.blog/"
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://aicomparehub.blog/"},
      {"@type": "ListItem", "position": 2, "name": "Tools", "item": "https://aicomparehub.blog/tools"}
    ]
  }
}
</script>